{
	"name": "downkit",
	"version": "0.0.2",
	"description": "turn markdown to routes",
	"license": "MIT",
	"author": "Boe Reh",
	"repository": "un-sv/downkit",
	"homepage": "https://downkit.unsv.dev",
	"scripts": {
		"dev": "vite dev",
		"build": "npm run prepack && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./context": {
			"types": "./dist/context.svelte.d.ts",
			"svelte": "./dist/context.svelte.js",
			"default": "./dist/context.svelte.js"
		},
		"./theme/svelte": {
			"types": "./dist/theme/svelte/index.d.ts",
			"svelte": "./dist/theme/svelte/index.js",
			"default": "./dist/theme/svelte/index.js"
		},
		"./theme/svelte/layout": {
			"types": "./dist/theme/svelte/layout.svelte.d.ts",
			"svelte": "./dist/theme/svelte/layout.svelte",
			"default": "./dist/theme/svelte/layout.svelte"
		},
		"./theme/bits": {
			"types": "./dist/theme/bits/index.d.ts",
			"svelte": "./dist/theme/bits/index.js",
			"default": "./dist/theme/bits/index.js"
		},
		"./theme/bits/layout": {
			"types": "./dist/theme/bits/layout.svelte.d.ts",
			"svelte": "./dist/theme/bits/layout.svelte",
			"default": "./dist/theme/bits/layout.svelte"
		},
		"./theme/melt": {
			"types": "./dist/theme/melt/index.d.ts",
			"svelte": "./dist/theme/melt/index.js",
			"default": "./dist/theme/melt/index.js"
		},
		"./theme/melt/layout": {
			"types": "./dist/theme/melt/layout.svelte.d.ts",
			"svelte": "./dist/theme/melt/layout.svelte",
			"default": "./dist/theme/melt/layout.svelte"
		}
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.57.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@types/unist": "^3.0.3",
		"@unocss/reset": "^66.7.0",
		"c12": "^4.0.0-beta.5",
		"chokidar": "^5.0.0",
		"citty": "^0.2.2",
		"defu": "^6.1.7",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tinyglobby": "^0.2.17",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unocss": "^66.7.0",
		"vite": "^8.0.7"
	},
	"keywords": [
		"svelte",
		"markdown"
	],
	"workspaces": [
		"*"
	],
	"dependencies": {
		"@iconify-json/lucide": "^1.2.111",
		"@iconify-json/simple-icons": "^1.2.85",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.5",
		"remark-frontmatter": "^5.0.0",
		"remark-parse": "^11.0.0",
		"runed": "^0.37.1",
		"satteri": "^0.9.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"uisv": "^0.0.23",
		"unified": "^11.0.5"
	}
}
